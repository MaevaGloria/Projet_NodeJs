                        <li><a href="/scolarite">Scolarité</a></li>
                        <li><a href="/concours">Concours</a></li>
                        <li><a href="/connexion">Connexion</a></li>
                        <li><a href="/inscription">Inscription</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5 class="mb-3">Contact</h5>
                    <ul class="footer-menu">
