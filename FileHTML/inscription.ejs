                </div>
            </div>
        </div>
        <div class="copyright">
            <div class="container">
                <p class="mb-0">© 2024 MonÉcole. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        // Validation du mot de passe en temps réel
        const passwordInput = document.getElementById('password');
        const confirmPasswordInput = document.getElementById('confirmPassword');
        const passwordRequirements = document.getElementById('passwordRequirements');
        const form = document.getElementById('inscriptionForm');

        const requirements = {
            length: /^.{8,}$/,
            uppercase: /[A-Z]/,
            lowercase: /[a-z]/,
            number: /[0-9]/,
            special: /[@$!%*?&#]/
        };

        // Afficher/masquer les exigences lors du focus/blur
        passwordInput.addEventListener('focus', function() {
            showPasswordRequirements();
        });

        passwordInput.addEventListener('blur', function() {
            setTimeout(() => {
                hidePasswordRequirements();
            }, 200);
        });

        // Validation en temps réel
        passwordInput.addEventListener('input', function() {
            const password = this.value;
            
            if (password.length > 0) {
                showPasswordRequirements();
            }
            
            // Vérifier chaque exigence
            updateRequirement('req-length', requirements.length.test(password));
            updateRequirement('req-uppercase', requirements.uppercase.test(password));
            updateRequirement('req-lowercase', requirements.lowercase.test(password));
            updateRequirement('req-number', requirements.number.test(password));
            updateRequirement('req-special', requirements.special.test(password));
            
            checkPasswordMatch();
        });

        confirmPasswordInput.addEventListener('input', checkPasswordMatch);

        function showPasswordRequirements() {
            passwordRequirements.classList.add('show');
            positionPasswordRequirements();
        }

        function hidePasswordRequirements() {
            passwordRequirements.classList.remove('show');
        }

        function positionPasswordRequirements() {
            const inputGroup = passwordInput.closest('.input-group');
            const rect = inputGroup.getBoundingClientRect();
            const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
            
            // Positionner sous le champ
            passwordRequirements.style.top = (rect.bottom + scrollTop + 10) + 'px';
            passwordRequirements.style.left = rect.left + 'px';
        }

        function updateRequirement(id, isValid) {
            const element = document.getElementById(id);
            const icon = element.querySelector('i');
            
            if (isValid) {
                element.classList.remove('invalid');
                element.classList.add('valid');
                icon.className = 'bi bi-check-circle-fill';
            } else {
                element.classList.remove('valid');
                element.classList.add('invalid');
                icon.className = 'bi bi-x-circle-fill';
            }
        }

        function checkPasswordMatch() {
            const password = passwordInput.value;
            const confirmPassword = confirmPasswordInput.value;
            const mismatchMessage = document.getElementById('passwordMismatch');
            
            if (confirmPassword && password !== confirmPassword) {
                confirmPasswordInput.classList.add('is-invalid');
                mismatchMessage.classList.remove('d-none');
            } else {
                confirmPasswordInput.classList.remove('is-invalid');
                mismatchMessage.classList.add('d-none');
            }
        }

        // Toggle visibility du mot de passe
        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById('toggle' + inputId.charAt(0).toUpperCase() + inputId.slice(1) + 'Icon');
            
            if (input.type === 'password') {
                input.type = 'text';
                icon.className = 'bi bi-eye-slash-fill';
            } else {
                input.type = 'password';
                icon.className = 'bi bi-eye-fill';
            }
        }

        // Validation finale avant soumission avec modal
        form.addEventListener('submit', function(e) {
            const password = passwordInput.value;
            const confirmPassword = confirmPasswordInput.value;
            
            // Vérifier toutes les exigences
            const allRequirementsMet = 
                requirements.length.test(password) &&
                requirements.uppercase.test(password) &&
                requirements.lowercase.test(password) &&
                requirements.number.test(password) &&
                requirements.special.test(password);
            
            if (!allRequirementsMet) {
                e.preventDefault();
                showPasswordErrorModal(password);
                return false;
            }
            
            if (password !== confirmPassword) {
                e.preventDefault();
                showPasswordMismatchModal();
                return false;
            }
        });

        // Afficher le modal d'erreur de mot de passe
        function showPasswordErrorModal(password) {
            const errorList = document.getElementById('passwordErrorList');
            errorList.innerHTML = '';
            
            const errors = [];
            
            if (!requirements.length.test(password)) {
                errors.push('<li><i class="bi bi-x-circle-fill"></i><span>Au moins <strong>8 caractères</strong></span></li>');
            }
            if (!requirements.uppercase.test(password)) {
                errors.push('<li><i class="bi bi-x-circle-fill"></i><span>Au moins une <strong>lettre majuscule</strong> (A-Z)</span></li>');
            }
            if (!requirements.lowercase.test(password)) {
                errors.push('<li><i class="bi bi-x-circle-fill"></i><span>Au moins une <strong>lettre minuscule</strong> (a-z)</span></li>');
            }
            if (!requirements.number.test(password)) {
                errors.push('<li><i class="bi bi-x-circle-fill"></i><span>Au moins un <strong>chiffre</strong> (0-9)</span></li>');
            }
            if (!requirements.special.test(password)) {
                errors.push('<li><i class="bi bi-x-circle-fill"></i><span>Au moins un <strong>caractère spécial</strong> (@$!%*?&)</span></li>');
            }
            
            errorList.innerHTML = errors.join('');
            
            const modal = new bootstrap.Modal(document.getElementById('passwordErrorModal'));
            modal.show();
            
            // Focus sur le champ password quand le modal se ferme
            document.getElementById('passwordErrorModal').addEventListener('hidden.bs.modal', function () {
                passwordInput.focus();
            }, { once: true });
        }

        // Afficher le modal d'erreur de correspondance
        function showPasswordMismatchModal() {
            const modal = new bootstrap.Modal(document.getElementById('passwordMismatchModal'));
            modal.show();
            
            // Focus sur le champ confirmation quand le modal se ferme
            document.getElementById('passwordMismatchModal').addEventListener('hidden.bs.modal', function () {
                confirmPasswordInput.focus();
            }, { once: true });
        }

        // Réinitialiser les validations lors du reset
        form.addEventListener('reset', function() {
            setTimeout(() => {
                document.querySelectorAll('.requirement').forEach(req => {
                    req.classList.remove('valid', 'invalid');
                    req.querySelector('i').className = 'bi bi-x-circle-fill';
                });
                document.getElementById('passwordMismatch').classList.add('d-none');
                confirmPasswordInput.classList.remove('is-invalid');
                hidePasswordRequirements();
            }, 10);
        });

        // Repositionner le popover lors du redimensionnement
        window.addEventListener('resize', function() {
            if (passwordRequirements.classList.contains('show')) {
                positionPasswordRequirements();
            }
        });

        // Masquer le popover lors du scroll
        window.addEventListener('scroll', function() {
            if (passwordRequirements.classList.contains('show') && 
                document.activeElement !== passwordInput) {
                hidePasswordRequirements();
            }
        });
    </script>
</body>
</html>