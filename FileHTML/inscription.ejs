    <div class="container">
        <div class="form-container">
            <div class="form-header">
                <i class="bi bi-person-plus-fill logo-icon"></i>
                <h2>Créer un compte</h2>
                <p>Inscrivez-vous pour accéder à notre plateforme</p>
            </div>

            <form id="inscriptionForm" action="/inscription" method="POST">
                <div class="row">
                    <!-- Nom complet -->
                    <div class="col-md-6 mb-3">
                        <label for="nom" class="form-label">
                            <i class="bi bi-person-fill"></i> Nom complet
                        </label>
                        <input type="text" class="form-control" id="nom" name="nom" 
                               placeholder="Entrez votre nom complet" required>
                    </div>

                    <!-- Email -->
                    <div class="col-md-6 mb-3">
                        <label for="email" class="form-label">
                            <i class="bi bi-envelope-fill"></i> Adresse email
                        </label>
                        <input type="email" class="form-control" id="email" name="email" 
                               placeholder="exemple@email.com" required>
                    </div>

                    <!-- Login -->
                    <div class="col-md-6 mb-3">
                        <label for="login" class="form-label">
                            <i class="bi bi-person-badge-fill"></i> Nom d'utilisateur
                        </label>
                        <input type="text" class="form-control" id="login" name="login" 
                               placeholder="Nom d'utilisateur" required minlength="4">
                        <small class="text-muted">Minimum 4 caractères</small>
                    </div>

                    <!-- Téléphone -->
                    <div class="col-md-6 mb-3">
                        <label for="telephone" class="form-label">
                            <i class="bi bi-telephone-fill"></i> Numéro de téléphone
                        </label>
                        <input type="tel" class="form-control" id="telephone" name="telephone" 
                               placeholder="+237 XXX XXX XXX" required pattern="[0-9+\s]{9,15}">
                    </div>

                    <!-- Mot de passe -->
                    <div class="col-12 mb-3 position-relative">
                        <label for="password" class="form-label">
                            <i class="bi bi-lock-fill"></i> Mot de passe
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-shield-lock-fill"></i>
                            </span>
                            <input type="password" class="form-control" id="password" name="password" 
                                   placeholder="Créez un mot de passe sécurisé" required autocomplete="new-password">
                            <span class="input-group-text password-toggle" onclick="togglePassword('password')">
                                <i class="bi bi-eye-fill" id="togglePasswordIcon"></i>
                            </span>
                        </div>
                        
                        <!-- Popover des exigences du mot de passe -->
                        <div class="password-requirements" id="passwordRequirements">
                            <h6><i class="bi bi-shield-check"></i> Exigences du mot de passe</h6>
                            <div class="requirement" id="req-length">
                                <i class="bi bi-x-circle-fill"></i>
                                <span>Au moins 8 caractères</span>
                            </div>
                            <div class="requirement" id="req-uppercase">
                                <i class="bi bi-x-circle-fill"></i>
                                <span>Une lettre majuscule (A-Z)</span>
                            </div>
                            <div class="requirement" id="req-lowercase">
                                <i class="bi bi-x-circle-fill"></i>
                                <span>Une lettre minuscule (a-z)</span>
                            </div>
                            <div class="requirement" id="req-number">
                                <i class="bi bi-x-circle-fill"></i>
                                <span>Un chiffre (0-9)</span>
                            </div>
                            <div class="requirement" id="req-special">
                                <i class="bi bi-x-circle-fill"></i>
                                <span>Un caractère spécial (@$!%*?&)</span>
                            </div>
                        </div>
                    </div>

                    <!-- Confirmation mot de passe -->
                    <div class="col-12 mb-4">
                        <label for="confirmPassword" class="form-label">
                            <i class="bi bi-lock-fill"></i> Confirmer le mot de passe
                        </label>
                        <div class="input-group">
                            <span class="input-group-text">
                                <i class="bi bi-shield-check-fill"></i>
                            </span>
                            <input type="password" class="form-control" id="confirmPassword" 
                                   name="confirmPassword" placeholder="Confirmez votre mot de passe" required autocomplete="new-password">
                            <span class="input-group-text password-toggle" onclick="togglePassword('confirmPassword')">
                                <i class="bi bi-eye-fill" id="toggleConfirmPasswordIcon"></i>
                            </span>
                        </div>
                        <small class="text-danger d-none" id="passwordMismatch">
                            <i class="bi bi-exclamation-circle-fill"></i> Les mots de passe ne correspondent pas
                        </small>
                    </div>
                </div>

                <!-- Boutons -->
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <button type="submit" class="btn btn-submit">
                            <i class="bi bi-check-circle-fill me-2"></i>S'inscrire
                        </button>
                    </div>
                    <div class="col-md-6">
                        <button type="reset" class="btn btn-reset">
                            <i class="bi bi-arrow-clockwise me-2"></i>Effacer
                        </button>
                    </div>
                </div>

                <!-- Lien vers connexion -->
                <div class="login-link">
                    <p class="mb-0">
                        Avez-vous déjà un compte ? 
                        <a href="/connexion">Connexion</a>
                    </p>
                </div>
            </form>
        </div>

        <div class="back-home">
            <a href="/acceuil">
                <i class="bi bi-house-fill me-2"></i>Retour à l'accueil
            </a>
        </div>
    </div>

    <!-- Modal d'erreur mot de passe -->
    <div class="modal fade" id="passwordErrorModal" tabindex="-1" aria-labelledby="passwordErrorModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="passwordErrorModalLabel">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Mot de passe invalide
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-3"><strong>Votre mot de passe ne respecte pas les exigences de sécurité.</strong></p>
                    <p class="mb-2">Un mot de passe sécurisé doit contenir :</p>
                    <ul class="error-list" id="passwordErrorList">
                        <!-- Les erreurs seront ajoutées dynamiquement ici -->
                    </ul>
                    <div class="alert alert-info mt-3 mb-0">
                        <i class="bi bi-lightbulb-fill me-2"></i>
                        <strong>Exemple de mot de passe valide :</strong> MonMotDePasse123!
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-modal-close" data-bs-dismiss="modal">
                        <i class="bi bi-check-circle me-2"></i>J'ai compris
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal d'erreur correspondance mot de passe -->
    <div class="modal fade" id="passwordMismatchModal" tabindex="-1" aria-labelledby="passwordMismatchModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="passwordMismatchModalLabel">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        Erreur de confirmation
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center py-3">
                        <i class="bi bi-shield-x" style="font-size: 4rem; color: var(--accent-color);"></i>
                        <h5 class="mt-3 mb-3">Les mots de passe ne correspondent pas</h5>
                        <p class="text-muted">Assurez-vous que les deux mots de passe sont identiques.</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-modal-close" data-bs-dismiss="modal">
                        <i class="bi bi-check-circle me-2"></i>Réessayer
                    </button>
                </div>
            </div>
        </div>
    </div>

